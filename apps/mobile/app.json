{
  "expo": {
    "name": "CardArena",
    "slug": "cardarena",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cardarena",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#262421"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardarena.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#262421"
      },
      "package": "com.cardarena.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "serverUrl": "https://playing-card-game-production.up.railway.app"
    }
  }
}
